# Default: normalize text files
* text=auto

# Keep common text sources LF on checkout/commit
*.go text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.env text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
Makefile text eol=lf
.editorconfig text eol=lf

# Git metadata / workspace files
.gitmodules text eol=lf
.obsidian/** text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.7z binary
